# Get a Google API key at https://console.cloud.google.com/
# Enable the Google Drive API and restrict the key to your domain.
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Airtable Personal Access Token — needed for the Copy Queue tab.
# Create one at https://airtable.com/create/tokens with read access to base appcEdGGPPfJNZYPG
VITE_AIRTABLE_API_KEY=your_airtable_api_key_here

# Figma Personal Access Token — needed for the Figma import in the Copy Queue.
# Create one at figma.com → Settings → Personal access tokens
VITE_FIGMA_API_TOKEN=your_figma_token_here
